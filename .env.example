# ============================================================
# ContractFlow Demo — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Obligatoire ──────────────────────────────────────────────
# Clé API Anthropic pour l'agent IA
ANTHROPIC_API_KEY=sk-ant-...

# ── Base de données PostgreSQL ───────────────────────────────
POSTGRES_USER=contractflow
POSTGRES_PASSWORD=contractflow_secret
POSTGRES_DB=contractflow

# ── Stockage objet MinIO ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

# ── Modèles LLM (optionnel, défauts définis dans compose) ────
# Modèle rapide pour extraction/classification
LLM_MODEL_FAST=claude-haiku-4-5-20251001
# Modèle intelligent pour analyse complexe
LLM_MODEL_SMART=claude-sonnet-4-6

# ── Langfuse — Observabilité LLM (optionnel) ─────────────────
# Nécessite : docker compose --profile observability up
# Si absent, le tracing est désactivé silencieusement
LANGFUSE_PUBLIC_KEY=pk-lf-contractflow-demo
LANGFUSE_SECRET_KEY=sk-lf-contractflow-demo
LANGFUSE_NEXTAUTH_SECRET=changeme_langfuse_nextauth_32chars_xx
LANGFUSE_SALT=changeme_salt_32chars_minimum_ok_xx

# ── ClickHouse (utilisé par Langfuse v3) ─────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse_secret

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
